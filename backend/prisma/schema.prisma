generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  STUDENT
  ADMIN
  SUPER_ADMIN
}

enum Stream {
  MPC
  BIPC
}

enum Subject {
  MATHS
  PHYSICS
  CHEMISTRY
  BIOLOGY
}

enum TestStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum ResourceType {
  BOOK
  QUESTION_BANK
  ANSWER_SCRIPT
}

// ─── User ────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  name         String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentProfile StudentProfile?

  // Relations
  testsCreated   Test[]         @relation("TestCreator")
  submissions    Submission[]
  resources      Resource[]     @relation("ResourceUploader")
  notifications  Notification[]
  remarksMade    Remark[]       @relation("RemarkTeacher")
  remarksReceived Remark[]      @relation("RemarkStudent")
  attendances    Attendance[]

  @@map("users")
}

// ─── Profiles ────────────────────────────────────────────

model StudentProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  stream          Stream
  rollNumber      String  @unique
  grade           String  @default("11")
  phone           String?
  guardianContact String?

  @@map("student_profiles")
}

// ─── Tests & Questions ───────────────────────────────────

model Test {
  id              String     @id @default(cuid())
  title           String
  description     String?
  type            String     @default("JEE")
  grade           String     @default("11")
  stream          Stream
  duration        Int        // minutes
  totalMarks      Int
  accessCode      String     @default("TEST")
  scheduledAt     DateTime?
  status          TestStatus @default(DRAFT)
  negativeMarking Boolean    @default(false)
  negativeMarks   Float      @default(0)
  createdById     String
  createdBy       User       @relation("TestCreator", fields: [createdById], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  questions   Question[]
  submissions Submission[]
  answerKey   AnswerKey?
  remarks     Remark[]

  @@map("tests")
}

model Question {
  id            String  @id @default(cuid())
  testId        String
  test          Test    @relation(fields: [testId], references: [id], onDelete: Cascade)
  questionNumber Int
  text          String
  imageUrl      String?
  options       Json    // ["Option A", "Option B", "Option C", "Option D"]
  correctOption Int     // 0-3 index
  marks         Int
  negativeMarks Float   @default(0)

  @@map("questions")
}

// ─── Submissions & Grading ───────────────────────────────

model Submission {
  id          String    @id @default(cuid())
  testId      String
  test        Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation(fields: [studentId], references: [id])
  answers     Json      // [{ questionId: string, selectedOption: number | null }]
  score       Float?
  totalMarks  Int?
  gradedAt    DateTime?
  submittedAt DateTime  @default(now())

  @@unique([testId, studentId])
  @@map("submissions")
}

model AnswerKey {
  id      String @id @default(cuid())
  testId  String @unique
  test    Test   @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers Json   // [{ questionId: string, correctOption: number }]
  createdAt DateTime @default(now())

  @@map("answer_keys")
}

// ─── Resources ───────────────────────────────────────────

model Resource {
  id             String       @id @default(cuid())
  type           ResourceType
  title          String
  description    String?
  subject        Subject
  stream         Stream
  fileUrl        String
  fileName       String
  fileSize       Int?
  uploadedById   String
  uploadedBy     User         @relation("ResourceUploader", fields: [uploadedById], references: [id])
  uploadedByRole Role
  createdAt      DateTime     @default(now())

  @@map("resources")
}

// ─── Notifications ───────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?  // Optional deep link
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ─── Remarks ─────────────────────────────────────────────

model Remark {
  id        String   @id @default(cuid())
  teacherId String
  teacher   User     @relation("RemarkTeacher", fields: [teacherId], references: [id])
  studentId String
  student   User     @relation("RemarkStudent", fields: [studentId], references: [id])
  testId    String?
  test      Test?    @relation(fields: [testId], references: [id])
  note      String
  createdAt DateTime @default(now())

  @@map("remarks")
}

// ─── Attendance ──────────────────────────────────────────

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  present   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([studentId, date])
  @@map("attendances")
}
